<section id="contato" class="py-20 bg-gradient-to-br from-verde to-verde-claro text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-2 gap-12">
      <!-- Lado esquerdo -->
      <div class="fade-in">
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-champagne mb-4">
          Entre em Contato
        </h2>
        <p class="text-white/80 mb-8 leading-relaxed">
          Ficou interessado? Mande uma mensagem ou preencha o formulário.
          Respondemos em até 24 horas!
        </p>

        <div class="space-y-4">
          <a id="contato-whatsapp" href="#" target="_blank" rel="noopener"
            class="flex items-center gap-3 bg-[#25D366] hover:bg-[#1da851] text-white px-6 py-3 rounded-xl font-semibold transition-colors">
            <svg class="w-5 h-5 fill-white" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Falar no WhatsApp
          </a>
          <a id="contato-instagram" href="#" target="_blank" rel="noopener"
            class="flex items-center gap-3 bg-white/15 hover:bg-white/25 text-white px-6 py-3 rounded-xl font-semibold transition-colors border border-white/20">
            <svg class="w-5 h-5 fill-white" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            Seguir no Instagram
          </a>
        </div>
      </div>

      <!-- Formulário -->
      <div class="fade-in">
        <form id="lead-form" class="bg-white rounded-2xl p-6 sm:p-8 shadow-lg overflow-hidden">
          <h3 class="font-display text-xl font-bold text-verde mb-6">Solicite um orçamento</h3>

          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Nome *</label>
              <input type="text" name="nome" required
                class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-verde focus:border-verde text-gray-800 box-border" />
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
                <input type="email" name="email" required
                  class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-verde focus:border-verde text-gray-800 box-border" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">WhatsApp *</label>
                <input type="tel" name="whatsapp" required inputmode="numeric" pattern="[0-9]*" id="whatsapp-input"
                  class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-verde focus:border-verde text-gray-800 box-border" />
              </div>
            </div>
            <div>
              <div class="flex items-center gap-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Data de nascimento</label>
                <span id="nasc-erro" class="text-red-500 text-xs hidden mb-1"></span>
              </div>
              <input type="date" name="data_nascimento" id="data-nascimento"
                class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-verde focus:border-verde text-gray-800 box-border" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Tipo de evento</label>
              <select name="tipo_evento"
                class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-verde focus:border-verde text-gray-800 box-border">
                <option value="">Selecione</option>
                <option value="Casamento">Casamento</option>
                <option value="Festa">Festa</option>
                <option value="Confraternização">Confraternização</option>
                <option value="Outro">Outro</option>
              </select>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Data início</label>
                <input type="date" name="data_inicio" id="data-inicio"
                  class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-verde focus:border-verde text-gray-800 box-border" />
              </div>
              <div>
                <div class="flex items-center gap-2">
                  <label class="block text-sm font-medium text-gray-700 mb-1">Data fim</label>
                  <span id="datafim-erro" class="text-red-500 text-xs hidden mb-1"></span>
                </div>
                <input type="date" name="data_fim" id="data-fim"
                  class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-verde focus:border-verde text-gray-800 box-border" />
              </div>
            </div>
            <div>
              <div class="flex items-center gap-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Nº de convidados</label>
                <span id="convidados-erro" class="text-red-500 text-xs hidden mb-1"></span>
              </div>
              <input type="number" name="num_convidados" min="1" max="200" id="num-convidados"
                class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-verde focus:border-verde text-gray-800 box-border" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Mensagem</label>
              <textarea name="mensagem" rows="3"
                class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-verde focus:border-verde text-gray-800 resize-none box-border"></textarea>
            </div>
          </div>

          <button type="submit" id="lead-submit"
            class="w-full mt-6 bg-verde text-white py-3 rounded-lg font-semibold hover:bg-verde-claro transition-colors">
            Enviar solicitação
          </button>

          <p id="lead-success" class="mt-4 text-center text-green-600 font-medium hidden">
            Recebemos! Em breve entraremos em contato
          </p>
          <p id="lead-error" class="mt-4 text-center text-red-500 text-sm hidden"></p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  import { supabase, db } from '../../lib/supabase.js'

  async function init() {
    try {
      const config = await db.config.listarPublico()
      if (config.whatsapp) {
        document.getElementById('contato-whatsapp').href = `https://wa.me/${config.whatsapp}`
      }
      if (config.instagram) {
        document.getElementById('contato-instagram').href = `https://instagram.com/${config.instagram}`
      }
    } catch {}

    const hoje = new Date().toISOString().split('T')[0]
    const dataInicio = document.getElementById('data-inicio')
    const dataFim = document.getElementById('data-fim')
    if (dataInicio) dataInicio.min = hoje
    if (dataFim) dataFim.min = hoje

    if (dataInicio && dataFim) {
      dataInicio.addEventListener('change', () => {
        if (dataInicio.value) {
          dataFim.min = dataInicio.value
          if (dataFim.value && dataFim.value < dataInicio.value) {
            dataFim.value = ''
          }
        }
      })
    }

    const dataNasc = document.getElementById('data-nascimento')
    if (dataNasc) {
      dataNasc.max = hoje
      dataNasc.addEventListener('change', () => {
        if (dataNasc.value > hoje) {
          dataNasc.value = ''
          showInlineError('nasc-erro', 'Não pode ser no futuro')
        }
      })
    }

    if (dataFim && dataInicio) {
      dataFim.addEventListener('change', () => {
        if (dataInicio.value && dataFim.value && dataFim.value < dataInicio.value) {
          dataFim.value = ''
          showInlineError('datafim-erro', 'Deve ser após a data início')
        }
      })
    }

    // WhatsApp só números
    const whatsInput = document.getElementById('whatsapp-input')
    if (whatsInput) {
      whatsInput.addEventListener('input', () => {
        whatsInput.value = whatsInput.value.replace(/[^0-9]/g, '')
      })
    }

    // Max convidados configurável
    let maxConvidados = 200
    try {
      const cfg = await db.config.listarPublico()
      if (cfg.max_convidados) maxConvidados = parseInt(cfg.max_convidados)
    } catch {}
    const numConvidados = document.getElementById('num-convidados')
    if (numConvidados) {
      numConvidados.max = maxConvidados
      numConvidados.addEventListener('input', () => {
        const val = parseInt(numConvidados.value)
        if (val > maxConvidados) {
          numConvidados.value = maxConvidados
          showInlineError('convidados-erro', `Máximo ${maxConvidados}`)
        }
        if (val < 1 && numConvidados.value !== '') numConvidados.value = 1
      })
    }
  }

  function showInlineError(id, msg) {
    const el = document.getElementById(id)
    if (!el) return
    el.textContent = msg
    el.classList.remove('hidden')
    setTimeout(() => el.classList.add('hidden'), 4000)
  }

  document.getElementById('lead-form').addEventListener('submit', async (e) => {
    e.preventDefault()
    const form = e.target
    const btn = document.getElementById('lead-submit')
    const successEl = document.getElementById('lead-success')
    const errorEl = document.getElementById('lead-error')

    btn.disabled = true
    btn.textContent = 'Enviando...'
    successEl.classList.add('hidden')
    errorEl.classList.add('hidden')

    const data = Object.fromEntries(new FormData(form))

    const hoje = new Date().toISOString().split('T')[0]
    if (data.data_inicio && data.data_inicio < hoje) {
      errorEl.textContent = 'A data de início não pode ser no passado.'
      errorEl.classList.remove('hidden')
      btn.disabled = false
      btn.textContent = 'Enviar solicitação'
      return
    }
    if (data.data_fim && data.data_inicio && data.data_fim < data.data_inicio) {
      errorEl.textContent = 'A data fim deve ser igual ou posterior à data início.'
      errorEl.classList.remove('hidden')
      btn.disabled = false
      btn.textContent = 'Enviar solicitação'
      return
    }

    try {
      const leadData = {
        nome: data.nome,
        email: data.email || null,
        whatsapp: data.whatsapp || null,
        data_nascimento: data.data_nascimento || null,
        tipo_evento: data.tipo_evento || null,
        data_inicio: data.data_inicio || null,
        data_fim: data.data_fim || null,
        num_convidados: data.num_convidados ? parseInt(data.num_convidados) : null,
        mensagem: data.mensagem || null
      }
      await db.leads.adicionar(leadData)

      successEl.classList.remove('hidden')
      const params = new URLSearchParams({
        nome: data.nome,
        data: data.data_inicio || ''
      })
      setTimeout(() => {
        window.location.href = `/obrigado?${params}`
      }, 2000)
    } catch (err) {
      errorEl.textContent = 'Erro ao enviar. Tente novamente ou fale pelo WhatsApp.'
      errorEl.classList.remove('hidden')
    } finally {
      btn.disabled = false
      btn.textContent = 'Enviar solicitação'
    }
  })

  init()
</script>
