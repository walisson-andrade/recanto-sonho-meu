<section id="sobre" class="py-20 bg-creme">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-2 gap-12 items-center fade-in">
      <!-- Visual placeholder -->
      <div class="relative">
        <div id="sobre-foto" class="aspect-[4/3] bg-gradient-to-br from-verde/10 to-dourado/10 rounded-2xl flex items-center justify-center border-2 border-dashed border-dourado/30 overflow-hidden">
          <div class="text-center p-8">
            <div class="text-6xl mb-4">🏡</div>
            <p class="text-gray-400 text-sm">Foto do espaço</p>
          </div>
        </div>
        <div class="absolute -bottom-4 -right-4 bg-dourado text-white px-6 py-3 rounded-xl font-display font-bold shadow-lg">
          Uberlândia, MG
        </div>
      </div>

      <!-- Texto -->
      <div>
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-verde mb-6">
          Um espaço feito para <span class="text-dourado">realizar sonhos</span>
        </h2>
        <p class="text-gray-600 leading-relaxed mb-8">
          O Recanto Sonho Meu é mais do que um salão de festas. É o cenário perfeito para
          os momentos mais especiais da sua vida. Com estrutura completa, ambiente acolhedor
          e muita natureza, transformamos cada evento em uma experiência inesquecível.
        </p>

        <!-- 4 cards -->
        <div class="grid grid-cols-2 gap-4 stagger">
          <div class="fade-in bg-white p-4 rounded-xl shadow-sm border border-gray-100 transition-all duration-300 hover:shadow-md hover:-translate-y-1">
            <div class="text-2xl mb-2">🏠</div>
            <h3 class="font-semibold text-verde text-sm">Salão</h3>
            <p class="text-gray-500 text-xs mt-1">Amplo e climatizado</p>
          </div>
          <div class="fade-in bg-white p-4 rounded-xl shadow-sm border border-gray-100 transition-all duration-300 hover:shadow-md hover:-translate-y-1">
            <div class="text-2xl mb-2">🌳</div>
            <h3 class="font-semibold text-verde text-sm">Área externa</h3>
            <p class="text-gray-500 text-xs mt-1">Jardim e churrasqueira</p>
          </div>
          <div class="fade-in bg-white p-4 rounded-xl shadow-sm border border-gray-100 transition-all duration-300 hover:shadow-md hover:-translate-y-1">
            <div class="text-2xl mb-2">🛏️</div>
            <h3 class="font-semibold text-verde text-sm">Hospedagem</h3>
            <p class="text-gray-500 text-xs mt-1">2 quartos disponíveis</p>
          </div>
          <div class="fade-in bg-white p-4 rounded-xl shadow-sm border border-gray-100 transition-all duration-300 hover:shadow-md hover:-translate-y-1">
            <div class="text-2xl mb-2">🚗</div>
            <h3 class="font-semibold text-verde text-sm">Estacionamento</h3>
            <p class="text-gray-500 text-xs mt-1">20 vagas no local</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { db } from '../../lib/supabase.js'
  import { esc } from '../../lib/helpers.js'

  async function carregarFotoCapa() {
    try {
      const fotos = await db.fotos.listarPublico()
      if (!fotos || fotos.length === 0) return

      const capa = fotos.find(f => f.categoria === 'geral') || fotos[0]
      const box = document.getElementById('sobre-foto')
      box.classList.remove('border-2', 'border-dashed', 'border-dourado/30', 'bg-gradient-to-br', 'from-verde/10', 'to-dourado/10')
      box.innerHTML = `<img src="${esc(capa.url)}" alt="${esc(capa.legenda) || 'Foto do espaço'}" class="w-full h-full object-cover" loading="lazy" />`
    } catch {}
  }

  carregarFotoCapa()
</script>
