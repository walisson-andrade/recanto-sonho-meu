    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="#" class="nav-logo font-display text-xl font-bold text-white">
        Recanto <span class="nav-logo-accent text-champagne">Sonho Meu</span>
      </a>

      <!-- Links desktop -->
      <div class="hidden md:flex items-center gap-6">
        <a href="#sobre" class="nav-link text-sm font-medium text-white/90 hover:text-white transition-colors">Sobre</a>
        <a href="#estrutura" class="nav-link text-sm font-medium text-white/90 hover:text-white transition-colors">Estrutura</a>
        <a href="#galeria" class="nav-link text-sm font-medium text-white/90 hover:text-white transition-colors">Galeria</a>
        <a href="#depoimentos" class="nav-link text-sm font-medium text-white/90 hover:text-white transition-colors">Depoimentos</a>
        <a href="#contato" class="nav-link text-sm font-medium text-white/90 hover:text-white transition-colors">Contato</a>
        <a href="#calculadora"
          class="bg-verde text-white px-5 py-2 rounded-full text-sm font-semibold hover:bg-verde-claro transition-colors">
          📅 Reservar
        </a>
      </div>

      <!-- Hambúrguer mobile -->
      <button id="menu-toggle" class="md:hidden p-2 text-white" aria-label="Abrir menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          <path id="menu-icon-close" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" class="hidden" />
        </svg>
      </button>
    </div>

    <!-- Menu mobile -->
    <div id="mobile-menu" class="md:hidden hidden pb-4 bg-white/95 backdrop-blur-md shadow-lg rounded-b-2xl -mx-4 px-4 mt-1">
      <div class="flex flex-col gap-2 pt-2">
        <a href="#sobre" class="nav-link-mobile px-4 py-2 text-sm font-medium text-gray-700 hover:bg-verde/5 hover:text-verde rounded-lg transition-colors">Sobre</a>
        <a href="#estrutura" class="nav-link-mobile px-4 py-2 text-sm font-medium text-gray-700 hover:bg-verde/5 hover:text-verde rounded-lg transition-colors">Estrutura</a>
        <a href="#galeria" class="nav-link-mobile px-4 py-2 text-sm font-medium text-gray-700 hover:bg-verde/5 hover:text-verde rounded-lg transition-colors">Galeria</a>
        <a href="#depoimentos" class="nav-link-mobile px-4 py-2 text-sm font-medium text-gray-700 hover:bg-verde/5 hover:text-verde rounded-lg transition-colors">Depoimentos</a>
