        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('nav')
  const menuToggle = document.getElementById('menu-toggle')
  const mobileMenu = document.getElementById('mobile-menu')
  const iconOpen = document.getElementById('menu-icon-open')
  const iconClose = document.getElementById('menu-icon-close')

  // Backdrop blur ao rolar + troca de cor do texto
  const navLinks = document.querySelectorAll('.nav-link')
  const navLinksMobile = document.querySelectorAll('.nav-link-mobile')
  const navLogo = document.querySelector('.nav-logo')
  const navLogoAccent = document.querySelector('.nav-logo-accent')

  function updateNavColors(scrolled) {
    if (scrolled) {
      nav.classList.add('bg-white/90', 'backdrop-blur-md', 'shadow-sm')
      navLogo.classList.remove('text-white')
      navLogo.classList.add('text-verde')
      navLogoAccent.classList.remove('text-champagne')
      navLogoAccent.classList.add('text-dourado')
      navLinks.forEach(l => { l.classList.remove('text-white/90'); l.classList.add('text-gray-700'); l.classList.remove('hover:text-white'); l.classList.add('hover:text-verde') })
      menuToggle.classList.remove('text-white')
      menuToggle.classList.add('text-verde')
    } else {
      nav.classList.remove('bg-white/90', 'backdrop-blur-md', 'shadow-sm')
      navLogo.classList.remove('text-verde')
      navLogo.classList.add('text-white')
      navLogoAccent.classList.remove('text-dourado')
      navLogoAccent.classList.add('text-champagne')
      navLinks.forEach(l => { l.classList.remove('text-gray-700'); l.classList.add('text-white/90'); l.classList.remove('hover:text-verde'); l.classList.add('hover:text-white') })
      menuToggle.classList.remove('text-verde')
      menuToggle.classList.add('text-white')
    }
  }

  window.addEventListener('scroll', () => {
    updateNavColors(window.scrollY > 50)
  })

  // Toggle menu mobile
  menuToggle.addEventListener('click', () => {
    const open = mobileMenu.classList.toggle('hidden')
    iconOpen.classList.toggle('hidden')
    iconClose.classList.toggle('hidden')
  })

  // Fechar menu ao clicar em link
  mobileMenu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden')
      iconOpen.classList.remove('hidden')
      iconClose.classList.add('hidden')
    })
  })
</script>
