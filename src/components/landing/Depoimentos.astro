<section id="depoimentos" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="font-display text-3xl sm:text-4xl font-bold text-verde mb-4 fade-in">
      O que dizem nossos clientes
    </h2>
    <p class="text-gray-500 mb-12 max-w-2xl mx-auto fade-in">
      Histórias reais de quem viveu momentos especiais no Recanto Sonho Meu.
    </p>

    <!-- Carrossel -->
    <div class="relative overflow-hidden fade-in">
      <div id="depoimentos-track" class="flex transition-transform duration-500 ease-in-out">
        <!-- Skeleton -->
        <div class="w-full flex-shrink-0 px-4">
          <div class="skeleton h-48 rounded-2xl max-w-lg mx-auto"></div>
        </div>
      </div>

      <!-- Controles -->
      <button id="dep-prev" class="absolute left-2 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white rounded-full p-2 shadow-md text-verde hidden">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </button>
      <button id="dep-next" class="absolute right-2 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white rounded-full p-2 shadow-md text-verde hidden">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </button>
    </div>

    <!-- Indicadores -->
    <div id="dep-dots" class="flex items-center justify-center gap-2 mt-6"></div>


    <!-- Fallback vazio -->
    <div id="dep-vazio" class="hidden py-8 fade-in">
      <div class="text-5xl mb-4">💬</div>
      <p class="text-gray-400">Nenhum depoimento ainda.</p>
    </div>
  </div>
</section>

<script>
  import { db } from '../../lib/supabase.js'
  import { gerarIniciais, esc } from '../../lib/helpers.js'

  let depoimentos = []
  let currentSlide = 0
  let autoPlayInterval = null

  async function init() {
    try {
      depoimentos = await db.depoimentos.listar()
    } catch { depoimentos = [] }

    if (depoimentos.length === 0) {
      document.getElementById('depoimentos-track').parentElement.classList.add('hidden')
      document.getElementById('dep-vazio').classList.remove('hidden')
      return
    }

    render()
    setupControls()
    startAutoPlay()
  }

  function render() {
    const track = document.getElementById('depoimentos-track')
    track.innerHTML = depoimentos.map(d => `
      <div class="w-full flex-shrink-0 px-4">
        <div class="bg-creme rounded-2xl p-8 max-w-lg mx-auto">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 rounded-full bg-verde text-white flex items-center justify-center font-bold text-sm">
              ${gerarIniciais(d.nome)}
            </div>
            <div class="text-left">
              <div class="font-semibold text-verde">${esc(d.nome)}</div>
              ${d.tipo_evento ? `<div class="text-xs text-gray-500">${esc(d.tipo_evento)}</div>` : ''}
            </div>
          </div>
          <p class="text-gray-600 italic leading-relaxed mb-4">"${esc(d.texto)}"</p>
          <div class="text-dourado">${'★'.repeat(d.avaliacao)}${'☆'.repeat(5 - d.avaliacao)}</div>
        </div>
      </div>
    `).join('')

    const dots = document.getElementById('dep-dots')
    dots.innerHTML = depoimentos.map((_, i) => `
      <button class="dep-dot w-2.5 h-2.5 rounded-full transition-colors ${i === 0 ? 'bg-verde' : 'bg-gray-300'}" data-i="${i}"></button>
    `).join('')
  }

  function goTo(index) {
    currentSlide = index
    const track = document.getElementById('depoimentos-track')
    track.style.transform = `translateX(-${currentSlide * 100}%)`
    document.querySelectorAll('.dep-dot').forEach((dot, i) => {
      dot.classList.toggle('bg-verde', i === currentSlide)
      dot.classList.toggle('bg-gray-300', i !== currentSlide)
    })
  }

  function setupControls() {
    const prevBtn = document.getElementById('dep-prev')
    const nextBtn = document.getElementById('dep-next')

    if (depoimentos.length > 1) {
      prevBtn.classList.remove('hidden')
      nextBtn.classList.remove('hidden')
    }

    prevBtn.addEventListener('click', () => {
      goTo((currentSlide - 1 + depoimentos.length) % depoimentos.length)
      resetAutoPlay()
    })
    nextBtn.addEventListener('click', () => {
      goTo((currentSlide + 1) % depoimentos.length)
      resetAutoPlay()
    })

    document.querySelectorAll('.dep-dot').forEach(dot => {
      dot.addEventListener('click', () => {
        goTo(Number(dot.dataset.i))
        resetAutoPlay()
      })
    })
  }

  function startAutoPlay() {
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    if (reducedMotion || depoimentos.length <= 1) return

    autoPlayInterval = setInterval(() => {
      goTo((currentSlide + 1) % depoimentos.length)
    }, 5000)

    const container = document.getElementById('depoimentos-track').parentElement
    container.addEventListener('mouseenter', () => clearInterval(autoPlayInterval))
    container.addEventListener('mouseleave', () => {
      clearInterval(autoPlayInterval)
      autoPlayInterval = setInterval(() => {
        goTo((currentSlide + 1) % depoimentos.length)
      }, 5000)
    })
  }

  function resetAutoPlay() {
    clearInterval(autoPlayInterval)
    startAutoPlay()
  }

  init()
</script>
