<section id="tour-virtual" class="py-20 bg-creme hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center fade-in">
    <h2 class="font-display text-3xl sm:text-4xl font-bold text-verde mb-4">
      Tour Virtual 360°
    </h2>
    <p class="text-gray-500 max-w-2xl mx-auto mb-8">
      Explore nosso espaço sem sair de casa.
    </p>
    <div class="aspect-video max-w-4xl mx-auto rounded-2xl overflow-hidden shadow-lg border border-gray-200">
      <iframe id="tour-iframe" class="w-full h-full" allowfullscreen loading="lazy"></iframe>
    </div>
  </div>
</section>

<script>
  import { db } from '../../lib/supabase.js'

  async function init() {
    try {
      const config = await db.config.listar()
      if (config.tour_virtual) {
        document.getElementById('tour-virtual').classList.remove('hidden')
        document.getElementById('tour-iframe').src = config.tour_virtual
      }
    } catch { /* seção permanece oculta */ }
  }

  init()
</script>
