<section id="estrutura" class="py-20 bg-verde text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="font-display text-3xl sm:text-4xl font-bold text-champagne mb-4 fade-in">
      Estrutura do Espaço
    </h2>
    <p class="text-white/70 mb-12 max-w-2xl mx-auto fade-in">
      Tudo o que você precisa para um evento perfeito, em um só lugar.
    </p>

    <!-- Grid com skeleton -->
    <div id="estrutura-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 fade-in">
      <!-- Skeleton loaders -->
      <div class="skeleton h-24 rounded-xl"></div>
      <div class="skeleton h-24 rounded-xl"></div>
      <div class="skeleton h-24 rounded-xl"></div>
      <div class="skeleton h-24 rounded-xl"></div>
    </div>
  </div>
</section>

<script>
  import { db } from '../../lib/supabase.js'

  async function carregarEstrutura() {
    const grid = document.getElementById('estrutura-grid')
    try {
      const itens = await db.estrutura.listar()
      if (itens.length === 0) {
        grid.innerHTML = '<p class="text-white/50 col-span-full">Nenhum item cadastrado.</p>'
        return
      }
      grid.innerHTML = itens.map(item => `
        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4 text-center border border-white/10">
          <div class="text-3xl mb-2">${item.icone}</div>
          <div class="text-2xl font-bold text-champagne">${item.quantidade}</div>
          <div class="text-sm text-white/80">${item.item}</div>
        </div>
      `).join('')
    } catch {
      grid.innerHTML = '<p class="text-white/50 col-span-full">Erro ao carregar estrutura.</p>'
    }
  }

  carregarEstrutura()
</script>
